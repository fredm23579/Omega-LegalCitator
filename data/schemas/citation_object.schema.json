{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/citation_object.schema.json",
  "title": "CitationObject",
  "type": "object",
  "required": ["raw_text", "normalized_citation", "source_type", "retrieved_at"],
  "properties": {
    "raw_text": {"type": "string"},
    "normalized_citation": {"type": "string"},
    "court": {"type": ["string", "null"]},
    "reporter": {"type": ["string", "null"]},
    "authority_title": {"type": ["string", "null"]},
    "source_type": {"type": "string"},
    "source_id": {"type": ["string", "null"]},
    "source_url": {"type": ["string", "null"]},
    "retrieved_at": {"type": "string"},
    "confidence": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
    "notes": {"type": ["string", "null"]}
  },
  "additionalProperties": false
}
